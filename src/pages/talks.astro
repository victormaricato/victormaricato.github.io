---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const items = (await getCollection('talks')).sort((a, b) => b.data.date.localeCompare(a.data.date));
---
<Base title="Talks — Victor Maricato">
  <h1>Talks &amp; media</h1>
  <ul class="list-none pl-0 space-y-4 mt-6">
    {items.map((t) => (
      <li>
        <div class="flex flex-wrap items-baseline gap-x-3">
          {t.data.url ? <a href={t.data.url} class="font-medium">{t.data.title}</a> : <span class="font-medium">{t.data.title}</span>}
          <span class="text-sm text-muted ml-auto">{t.data.date}</span>
        </div>
        <div class="text-sm text-muted">{t.data.venue}</div>
      </li>
    ))}
  </ul>
</Base>
