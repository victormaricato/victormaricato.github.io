---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Victor Maricato', description = 'Senior Machine Learning Engineer. ML, health informatics, and medicine.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Victor Maricato',
  url: 'https://victormaricato.me/',
  image: 'https://victormaricato.me/images/profile.jpg',
  jobTitle: 'Staff Machine Learning Engineer',
  worksFor: { '@type': 'Organization', name: 'Upwork' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'Karolinska Institutet' },
    { '@type': 'CollegeOrUniversity', name: 'MIT CSAIL' },
  ],
  address: { '@type': 'PostalAddress', addressLocality: 'Stockholm', addressCountry: 'SE' },
  sameAs: [
    'https://github.com/victormaricato',
    'https://www.linkedin.com/in/victormaricato/',
    'https://x.com/coffeeshopperr',
    'https://scholar.google.com/citations?user=WaAoUqsAAAAJ&hl=en',
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    )}
  </head>
  <body class="font-sans">
    <main class="max-w-prose mx-auto px-5 py-10 md:py-16">
      <Nav />
      <slot />
      <Footer />
    </main>
  </body>
</html>
